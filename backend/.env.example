# Copy to .env and adjust for your environment.

# Flask
FLASK_APP=run.py
FLASK_CONFIG=development

# Security — set a long random value in production.
SECRET_KEY=change-me-to-a-long-random-string

# Database (defaults to a local SQLite file in backend/instance/library.db)
# DATABASE_URL=sqlite:///instance/library.db

# Library rules
LOAN_PERIOD_DAYS=14
FINE_PER_DAY=10
MAX_ACTIVE_LOANS=5

# CORS — use a specific origin in production, e.g. http://localhost:5173
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Safaricom Daraja (M-Pesa) — STK Push for paying fines
# ---------------------------------------------------------------------------
# sandbox or production
MPESA_ENV=sandbox
# From https://developer.safaricom.co.ke (My Apps → Consumer Key / Secret)
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
# Sandbox defaults shown; override for production with your paybill/till + passkey
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# CustomerPayBillOnline (paybill) or CustomerBuyGoodsOnline (till)
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# Public URL Daraja can reach (e.g. an ngrok/cloudflared tunnel during dev).
# The callback path (/api/payments/callback) is appended automatically.
MPESA_CALLBACK_BASE_URL=
